---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  fullWidth?: boolean;
}

const { src, alt, caption, fullWidth = false } = Astro.props;
---

<figure class:list={['figure', { 'figure--full': fullWidth }]}>
  <img src={src} alt={alt} class="figure__image" loading="lazy" />
  {caption && <figcaption class="figure__caption">{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin: var(--space-8) 0;
  }

  .figure--full {
    margin-left: calc(-1 * var(--space-6));
    margin-right: calc(-1 * var(--space-6));
  }

  /* On >=768px the article grid has real gutters; bleed into them using the
     SAME per-tier tokens the grid uses (--grid-left-gutter / --grid-right-gutter,
     set on .article-layout and inherited here). Because those tokens are
     redefined at the medium tier (768-1023px) alongside the grid columns, the
     figure bleed tracks the grid at every breakpoint and can never diverge or
     overflow the card. */
  @media (min-width: 768px) {
    .figure--full {
      margin-left: calc(-1 * (var(--grid-left-gutter) + var(--article-gap)));
      margin-right: calc(-1 * (var(--grid-right-gutter) + var(--article-gap)));
    }
  }

  .figure__image {
    width: 100%;
    height: auto;
    border: var(--border);
    border-radius: var(--radius-md);
  }

  .figure__caption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    font-style: italic;
  }
</style>
