---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { isVisible } from '@/lib/posts';

export async function getStaticPaths() {
  // isVisible hides drafts in production builds (so their pages are never
  // generated) and shows them in dev for local preview.
  const posts = await getCollection('blog', isVisible);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await post.render();
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  heroImage={post.data.heroImage || `/og/${post.slug}.png`}
  headings={headings}
>
  <Content />
</BlogLayout>
