---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/global/Header.astro';
import Footer from '@/components/global/Footer.astro';
import Card from '@/components/global/Card.astro';
import PostCard from '@/components/blog/PostCard.astro';
import NewsletterCard from '@/components/newsletter/NewsletterCard.astro';
import { getVisiblePosts } from '@/lib/posts';

const posts = await getVisiblePosts();
---

<BaseLayout title="Dereferenced — Akshay Manglik" description="Ideas, traced to source." image="/og/dereferenced.png">
  <div class="page">
    <div class="container">
      <Card>
        <Header currentPath="/dereferenced" />
        <div class="post-cards">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.slug}
            />
          ))}
          <NewsletterCard variant="listing" />
        </div>
        <Footer />
      </Card>
    </div>
  </div>
</BaseLayout>
