---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/global/Header.astro';
import Footer from '@/components/global/Footer.astro';
import Card from '@/components/global/Card.astro';
import PostCard from '@/components/blog/PostCard.astro';
import NewsletterCard from '@/components/newsletter/NewsletterCard.astro';
import { getVisiblePosts } from '@/lib/posts';

const posts = await getVisiblePosts();
---

<BaseLayout title="Dereferenced — Akshay Manglik" description="Ideas, traced to source." image="/og/dereferenced.png">
  <div class="page">
    <div class="container">
      <Card>
        <Header currentPath="/dereferenced" />
        <div class="post-cards">
          {posts.length === 0 && (
            <p class="posts-empty">No posts yet — new writing is in the works. Subscribe below to get the first one.</p>
          )}
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.slug}
            />
          ))}
          <NewsletterCard variant="listing" />
        </div>
        <Footer />
      </Card>
    </div>
  </div>
</BaseLayout>

<style>
  .posts-empty {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    margin: 0;
    padding: var(--space-2) 0 var(--space-4);
  }
</style>
